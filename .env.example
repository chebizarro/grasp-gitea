GITEA_URL=http://gitea:3000
GITEA_ADMIN_TOKEN=
# Required: public URL prefix for git clone URLs (must match NIP-34 clone tags)
CLONE_PREFIX=https://git.example.com
RELAY_URLS=ws://gastown-relay:3334
HOOK_RELAY_URL=ws://localhost:3334
HOOK_BINARY_PATH=/usr/local/bin/grasp-pre-receive
GITEA_REPOSITORIES_PATH=/gitea-data/git/repositories
LISTEN=:8090
DB_PATH=./mappings.db
PUBKEY_ALLOWLIST=
PROVISION_RATE_LIMIT=10
ADMIN_API_TOKEN=

# NIP-34 outbound publishing (PRs, issues, patches, labels)
# BRIDGE_NSEC: Server signing key (nsec or hex) for publishing NIP-34 events
# GITEA_WEBHOOK_SECRET: HMAC secret shared with Gitea system webhook
BRIDGE_NSEC=
GITEA_WEBHOOK_SECRET=
